# ── Phase 2.2: budget pools (USD/month, 70/15/15) ───────────────────────
MONTHLY_BUDGET_USD=100.0
BUDGET_SPLIT_CEO=0.70
BUDGET_SPLIT_HR=0.15
BUDGET_SPLIT_KEVIN=0.15

# ── Phase 2.2: HR cadence (UTC) ─────────────────────────────────────────
