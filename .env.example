# ═════════════════════════════════════════════════════════════════════════
# Investment Fund — Phase 2.3 .env template
#   copy to .env and fill in secrets; never commit .env
# ═════════════════════════════════════════════════════════════════════════

# ── Secrets ──────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-REPLACE_ME

# ── Infrastructure ───────────────────────────────────────────────────────
MARKET_SIM_URL=http://market_sim:8001
DB_PATH=/data/fund.db
LOG_LEVEL=INFO

# ── Trading universe (Yahoo Finance tickers) ─────────────────────────────
# Simone's real holdings, II + Revolut. See fund/assets.py for threshold
# calibration per ticker.
#
# Interactive Investor:
#   AMZN, EQQQ.L, SPAG.L, MINE.L, CS51.L, SSAC.L, SGLN.L, IGUS.L,
#   BCOG.L, MUT.L, VMIG.L, VWRP.L, VUSA.L, AGAP.L, COPB.L
# Revolut:
#   TSM, NVDA, GOOGL, META, VUAA.L, EUDF.L, 5J50.DE, MAERSK-B.CO,
#   GC=F, BTC-USD
#
ASSETS=AMZN,EQQQ.L,SPAG.L,MINE.L,CS51.L,SSAC.L,SGLN.L,IGUS.L,BCOG.L,MUT.L,VMIG.L,VWRP.L,VUSA.L,AGAP.L,COPB.L,TSM,NVDA,GOOGL,META,VUAA.L,EUDF.L,5J50.DE,MAERSK-B.CO,GC=F,BTC-USD

# ── Risk gates ───────────────────────────────────────────────────────────
# MOMENTUM_THRESHOLD is a fallback; per-asset thresholds in fund/assets.py
# override it. Leave at 0.015 (1.5%) as a reasonable mid-universe default.
MOMENTUM_THRESHOLD=0.015
CONFIDENCE_THRESHOLD=0.70
MAX_POSITION_USD=2000.0

# ── Loop cadence ─────────────────────────────────────────────────────────
CHECK_INTERVAL_SECONDS=60

# ── Budget (USD, LLM spend only; 70/15/15 across CEO/HR/Kevin) ───────────
MONTHLY_BUDGET_USD=100.0
BUDGET_SPLIT_CEO=0.70
BUDGET_SPLIT_HR=0.15
BUDGET_SPLIT_KEVIN=0.15

# ── Principals' models ───────────────────────────────────────────────────
CEO_MODEL=anthropic/claude-sonnet-4-5-20250929
KEVIN_MODEL=anthropic/claude-haiku-4-5-20251001
HR_MODEL=anthropic/claude-haiku-4-5-20251001
SPECIALIST_DEFAULT_MODEL=anthropic/claude-haiku-4-5-20251001

# ── Reports cadence (UTC) ────────────────────────────────────────────────
DAILY_REPORT_HOUR=18
WEEKLY_REPORT_DAY=MON
WEEKLY_REPORT_HOUR=9
MONTHLY_REPORT_DAY=1
MONTHLY_REPORT_HOUR=9
BENCHMARK_SYMBOL=VWRP.L

# ── HR weekly review (UTC) ───────────────────────────────────────────────
HR_REVIEW_DAY=MON
HR_REVIEW_HOUR_UTC=9

# ── Dashboard ────────────────────────────────────────────────────────────
DASHBOARD_HOST=0.0.0.0
DASHBOARD_PORT=8080

# ── Kevin audit gate ─────────────────────────────────────────────────────
KEVIN_DEBUG_GATE=true
