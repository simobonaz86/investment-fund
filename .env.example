# Copy this file to .env and fill in your values.
# Never commit .env to git.

# ── Required ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Infrastructure ────────────────────────────────────────────────────────────
MARKET_SIM_URL=http://localhost:8001
DB_PATH=data/fund.db

# ── Trading universe ──────────────────────────────────────────────────────────
ASSETS=SYN-A,SYN-B,SYN-C

# ── Signal thresholds ─────────────────────────────────────────────────────────
MOMENTUM_THRESHOLD=0.03      # 3% price move triggers Research hire
CONFIDENCE_THRESHOLD=0.70    # min Research confidence to trade
MAX_POSITION_USD=1000.0      # hard per-trade cap

# ── Budget ────────────────────────────────────────────────────────────────────
MONTHLY_BUDGET_USD=50.0      # Board-controlled monthly agent API spend cap

# ── Loop ──────────────────────────────────────────────────────────────────────
CHECK_INTERVAL_SECONDS=60    # how often to scan for signals

# ── Models ────────────────────────────────────────────────────────────────────
MANAGER_MODEL=anthropic/claude-haiku-4-5-20251001
SPECIALIST_MODEL=anthropic/claude-haiku-4-5-20251001

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO               # DEBUG to see full CrewAI traces
