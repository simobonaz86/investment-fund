# Copy this file to .env and fill in your values.

# ── Required ──────────────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── Per-agent models ──────────────────────────────────────────────────────────
# Manager synthesises → Sonnet.  Specialists are narrow → Haiku.
MANAGER_MODEL=anthropic/claude-sonnet-4-6
RESEARCH_MODEL=anthropic/claude-haiku-4-5-20251001
RISK_MODEL=anthropic/claude-haiku-4-5-20251001
EXECUTION_MODEL=anthropic/claude-haiku-4-5-20251001
REFLECTION_MODEL=anthropic/claude-haiku-4-5-20251001

# ── Infra ─────────────────────────────────────────────────────────────────────
MARKET_SIM_URL=http://market_sim:8001
DB_PATH=/data/fund.db
CONTROL_PORT=8002

# ── Weekly spend caps (testing values — $1 total) ─────────────────────────────
# Runtime thresholds (assets, momentum %, confidence) are in the DB `control` table,
# editable via the control API at runtime.  These caps are hard safety limits.
WEEKLY_BUDGET_TOTAL_USD=1.00
WEEKLY_BUDGET_RESEARCH_USD=0.40
WEEKLY_BUDGET_RISK_USD=0.20
WEEKLY_BUDGET_SENTIMENT_USD=0.15
WEEKLY_BUDGET_EXECUTION_USD=0.10
WEEKLY_BUDGET_REFLECTION_USD=0.10
WEEKLY_BUDGET_ACCOUNTANT_USD=0.05

# ── Logging ───────────────────────────────────────────────────────────────────
LOG_LEVEL=INFO
